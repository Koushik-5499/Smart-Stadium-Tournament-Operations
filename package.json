{
  "name": "smart-stadium-wc2026",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "GenAI-enabled Smart Stadium & Tournament Operations platform for FIFA World Cup 2026",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src/ --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "set-staff-claim": "node scripts/setStaffClaim.mjs"
  },
  "devDependencies": {
    "@axe-core/puppeteer": "^4.12.1",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vercel/node": "^5.8.23",
    "@vitejs/plugin-react": "^4.5.2",
    "axe-core": "^4.12.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "puppeteer": "^25.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@axe-core/react": "^4.12.1",
    "@types/leaflet": "^1.9.21",
    "@vitejs/plugin-react": "^4.5.2",
    "firebase": "^12.15.0",
    "firebase-admin": "^13.10.0",
    "leaflet": "^1.9.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.18.1"
  }
}
