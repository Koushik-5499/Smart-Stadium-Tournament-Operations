# Firebase Configuration (client-side, safe to expose)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=smart-stadium-wc2026.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=smart-stadium-wc2026
VITE_FIREBASE_STORAGE_BUCKET=smart-stadium-wc2026.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# Gemini API Key — SERVER-SIDE ONLY
# This key is NOT prefixed with VITE_ and is NOT bundled into the client.
# Set it in the Vercel dashboard under Environment Variables for Production,
# Preview, and Development environments.
# GEMINI_API_KEY=your-gemini-api-key  (set in Vercel, not here)
